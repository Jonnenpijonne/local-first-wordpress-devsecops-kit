{"translation-revision-date":"2026-05-27 05:06:06+0000","generator":"GlotPress\/4.0.3","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","plural-forms":"nplurals=2; plural=n != 1;","lang":"fi"},"Font family to uninstall is not defined.":["Poistettavaa fonttiperhett\u00e4 ei ole m\u00e4\u00e4ritelty."],"paging\u0004<div>Page<\/div>%1$s<div>of %2$d<\/div>":["<div>Sivu<\/div>%1$s<div>\/%2$d<\/div>"],"noun\u0004Upload":["Siirr\u00e4"],"variation label\u0004%1$s (%2$s)":["%1$s (%2$s)"],"There was an error updating the font family. %s":["Fonttiperheen p\u00e4ivitt\u00e4misess\u00e4 tapahtui virhe. %s"],"font source\u0004Custom":["Mukautettu"],"font source\u0004Theme":["Teema"],"Font family updated successfully.":["Fonttiperhe p\u00e4ivitettiin onnistuneesti."],"Lowercase letter A\u0004a":["a"],"Uppercase letter A\u0004A":["A"],"Font library\u0004Library":["Fontti-kirjasto"],"There was an error installing fonts.":["Fonttien asentamisessa tapahtui virhe."],"No fonts installed.":["Fontteja ei asennettu."],"Uploaded fonts appear in your library and can be used in your theme. Supported formats: .ttf, .otf, .woff, and .woff2.":["Ladatut fontit n\u00e4kyv\u00e4t kirjastossa ja niit\u00e4 voidaan k\u00e4ytt\u00e4\u00e4 teemassasi. Tuetut tiedostomuodot: .tff, .otf, .woff ja .woff2."],"No fonts found to install.":["Asennettavia fontteja ei l\u00f6ytynyt."],"Current page":["Nykyinen sivu"],"Revoke access to Google Fonts":["Poista p\u00e4\u00e4sy Google Fonts -palveluun"],"Error installing the fonts, could not be downloaded.":["Virhe fonttien asennuksessa, ei voitu ladata."],"font categories\u0004All":["Kaikki"],"Connect to Google Fonts":["Yhdist\u00e4 Google Fonts -palveluun"],"Are you sure you want to delete \"%s\" font and all its variants and assets?":["Haluatko varmasti poistaa fontin \"%s\", kaikki sen muunnelmat ja tiedostot?"],"There was an error uninstalling the font family.":["Fonttiperheen poistamisessa tapahtui virhe."],"%d variant":["%d muunnelma","